{
  "manifest_version": 3,
  "name": "拾图",
  "short_name": "拾图",
  "version": "0.1.5",
  "description": "悬停网页图片即可拾取，通过侧边栏批量下载原图。支持打包 ZIP、逐张保存或导出链接列表，也可粘贴图片直链直接下载。已适配多个主流图片与灵感网站。",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "declarativeNetRequest",
    "downloads",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "referer-rules",
        "enabled": true,
        "path": "rules/referer.json"
      }
    ]
  },
  "host_permissions": [],
  "optional_host_permissions": [
    "https://*.xiaohongshu.com/*",
    "https://xiaohongshu.com/*",
    "https://*.xhscdn.com/*",
    "https://*.pinterest.com/*",
    "https://pinterest.com/*",
    "https://*.pinimg.com/*",
    "https://*.x.com/*",
    "https://x.com/*",
    "https://*.twitter.com/*",
    "https://twitter.com/*",
    "https://pbs.twimg.com/*",
    "https://mp.weixin.qq.com/*",
    "https://mmbiz.qpic.cn/*",
    "https://mmbiz.qlogo.cn/*",
    "https://*.500px.com/*",
    "https://500px.com/*",
    "https://*.500px.org/*",
    "https://*.duitang.com/*",
    "https://duitang.com/*",
    "https://*.dtstatic.com/*",
    "https://*.huaban.com/*",
    "https://huaban.com/*",
    "https://*.dribbble.com/*",
    "https://dribbble.com/*",
    "https://*.instagram.com/*",
    "https://instagram.com/*",
    "https://*.cdninstagram.com/*",
    "https://*.fbcdn.net/*",
    "https://*.behance.net/*",
    "https://behance.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "拾图",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  }
}
